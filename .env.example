# ============================================================
# Sao chép file này thành .env rồi điền key thật.
# Web hỗ trợ MỌI nhà cung cấp tương thích chuẩn OpenAI —
# chỉ cần đổi 3 biến: KEY, BASE_URL, MODEL.
# ============================================================

# ----- CÁCH 1: GROQ (MIỄN PHÍ, khuyên dùng) -----
# Lấy key free tại: https://console.groq.com/keys  (key dạng gsk_...)
OPENAI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.groq.com/openai/v1
# Model đọc được ẢNH (multimodal, free). Nếu Groq đổi tên model,
# xem danh sách hiện hành tại https://console.groq.com/docs/models
OPENAI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct


# ----- CÁCH 2: OPENAI (trả phí, rẻ) -----
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini


# ----- CÁCH 3: endpoint tương thích OpenAI khác -----
# (bất kỳ dịch vụ nào có /chat/completions kiểu OpenAI — đổi 3 biến trên cho khớp)
